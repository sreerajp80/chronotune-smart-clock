<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_digital_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background_a50"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="true">

        <TextClock
            android:id="@+id/widget_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:format12Hour="hh:mm"
            android:format24Hour="HH:mm"
            android:fontFamily="monospace"
            android:textColor="#FFF9EE"
            android:textSize="30sp"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            android:shadowColor="#FF000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="6" />

        <TextClock
            android:id="@+id/widget_seconds"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:format12Hour=":ss"
            android:format24Hour=":ss"
            android:fontFamily="monospace"
            android:textColor="#FFE3B0"
            android:textSize="14sp"
            android:textStyle="bold"
            android:shadowColor="#FF000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="4" />

        <TextClock
            android:id="@+id/widget_ampm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:format12Hour="a"
            android:format24Hour=""
            android:fontFamily="monospace"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.10"
            android:shadowColor="#FF000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="4" />
    </LinearLayout>

    <TextClock
        android:id="@+id/widget_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:format12Hour="EEE, MMM d"
        android:format24Hour="EEE, MMM d"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:shadowColor="#FF000000"
        android:shadowDx="0"
        android:shadowDy="1"
        android:shadowRadius="4" />
</LinearLayout>
